/*
 * override/cstdlib — C++ <cstdlib> with C99/POSIX extensions for Solaris 7
 *
 * GCC's <cstdlib> does "using ::atoll;" etc. to pull C symbols into
 * namespace std.  But Solaris 7's <stdlib.h> doesn't declare atoll,
 * setenv, unsetenv, strtoll, strtoull, or other C99/POSIX additions.
 *
 * Fix: include our override stdlib.h first (which adds the missing
 * declarations to the global namespace), then let GCC's <cstdlib>
 * pull them into std::.
 *
 * Part of libsolcompat — https://github.com/Sunstorm-Project/libsolcompat
 */
#ifndef _SOLCOMPAT_OVERRIDE_CSTDLIB
#define _SOLCOMPAT_OVERRIDE_CSTDLIB

/*
 * First let GCC's real <cstdlib> run — it includes the system <stdlib.h>
 * internally and pulls whatever Solaris 7 provides into namespace std.
 */
#include_next <cstdlib>

/*
 * Now declare the C99/POSIX functions that Solaris 7's stdlib.h lacked.
 * These go into the global namespace (::), then we pull them into std::.
 */
#include <solcompat/stdlib_ext.h>

namespace std {
    using ::atoll;
    using ::strtoll;
    using ::strtoull;
    using ::strtof;
    using ::strtold;
    using ::setenv;
    using ::unsetenv;
    using ::mkdtemp;
}

#endif /* _SOLCOMPAT_OVERRIDE_CSTDLIB */
